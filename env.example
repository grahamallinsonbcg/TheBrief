# Required: Anthropic API key for article summarisation and stream classification
ANTHROPIC_API_KEY=

# Optional: Firecrawl API key for scraping company blog pages
# Without this, scrape sources are skipped (RSS and web search still work)
FIRECRAWL_API_KEY=

# Optional: Tavily API key for LLM-powered web search discovery
# Without this, web search is skipped (RSS and scrape still work)
TAVILY_API_KEY=

# Required for the /sources page "Save for next run" button
# Set to any secret string; pass the same value as x-admin-token when saving
SOURCE_CONFIG_ADMIN_TOKEN=

# Optional: URL of a remotely-hosted source_inputs.runtime.json
# Only needed if the pipeline runs on a machine that doesn't have the repo checked out.
# When running via GitHub Actions the repo checkout is used directly — leave this unset.
SOURCE_INPUTS_REMOTE_URL=
